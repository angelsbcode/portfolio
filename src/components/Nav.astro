---
// src/components/Nav.astro
---
<nav id="nav" class="absolute top-0 w-full bg-[#f7f7f7] rounded-t-[0.25em] transition-all duration-300 ease-in-out py-[1em] text-center">
  <ul id="nav-list" class="flex flex-wrap justify-center m-0 p-0 list-none">
    <li class="mx-[0.35em] inline-block">
      <a href="#intro" class="nav-link inline-block h-[2.25em] leading-[2.25em] px-[1.25em] rounded-[8px] transition-all duration-300 hover:bg-[rgba(222,222,222,0.25)] text-[#636363] text-[1em]">Introduction</a>
    </li>
    <li class="mx-[0.35em] inline-block">
      <a href="#first" class="nav-link inline-block h-[2.25em] leading-[2.25em] px-[1.25em] rounded-[8px] transition-all duration-300 hover:bg-[rgba(222,222,222,0.25)] text-[#636363] text-[1em]">First Section</a>
    </li>
    <li class="mx-[0.35em] inline-block">
      <a href="#second" class="nav-link inline-block h-[2.25em] leading-[2.25em] px-[1.25em] rounded-[8px] transition-all duration-300 hover:bg-[rgba(222,222,222,0.25)] text-[#636363] text-[1em]">Second Section</a>
    </li>
    <li class="mx-[0.35em] inline-block">
      <a href="#cta" class="nav-link inline-block h-[2.25em] leading-[2.25em] px-[1.25em] rounded-[8px] transition-all duration-300 hover:bg-[rgba(222,222,222,0.25)] text-[#636363] text-[1em]">Get Started</a>
    </li>
  </ul>
</nav>

<script>
  const nav = document.getElementById('nav');
  const navLinks = document.querySelectorAll('.nav-link');
  // Usamos el centinela estático que ahora está FUERA del flujo del nav
  const sentinel = document.getElementById('nav-sentinel');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      // Si el centinela invisible cruza el techo de la pantalla
      if (!entry.isIntersecting && entry.boundingClientRect.bottom <= 0) {
        
        // Efecto Shrink (Encoger)
        nav.classList.remove('py-[1em]', 'rounded-t-[0.25em]', 'bg-[#f7f7f7]');
        nav.classList.add('py-[0.5em]', 'rounded-none', 'bg-[rgba(247,247,247,0.95)]', 'shadow-md');
        
        navLinks.forEach(link => {
          link.classList.remove('text-[1em]');
          link.classList.add('text-[0.9em]');
        });

      } else {
        
        // Volver a la normalidad
        nav.classList.add('py-[1em]', 'rounded-t-[0.25em]', 'bg-[#f7f7f7]');
        nav.classList.remove('py-[0.5em]', 'rounded-none', 'bg-[rgba(247,247,247,0.95)]', 'shadow-md');
        
        navLinks.forEach(link => {
          link.classList.add('text-[1em]');
          link.classList.remove('text-[0.9em]');
        });

      }
    });
  }, { threshold: 0 });

  if (sentinel) observer.observe(sentinel);
</script>
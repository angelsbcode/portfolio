---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import fotoIntro from '../assets/images/pic01.jpg';
---

<BaseLayout title="Stellar by HTML5 UP - Astro Version">
  <div id="wrapper" class="w-[64em] max-w-[calc(100%-4em)] mx-auto py-[4em] flex flex-col">
    
    <Header />

    <div id="nav-sentinel" class="w-full h-0"></div>

    <div class="sticky top-0 z-50 w-full h-0">
      <Nav />
    </div>

    <main id="main" class="mt-[4.25em] bg-white rounded-b-[0.25em] shadow-2xl text-[#636363]">

      <Section id="intro" class="p-[4em] md:p-[5em] border-b border-[#dddddd]">
        <div class="flex flex-col-reverse md:flex-row items-center gap-[4em]">
          <div class="flex-1 text-left">
            <header class="mb-[1.5em] relative">
              <h2 class="text-[2.25em] font-light text-[#636363] leading-[1.3] mb-4">Ipsum sed adipiscing</h2>
              <div class="w-[3em] h-[2px] bg-gradient-to-r from-pink-400 to-blue-400"></div>
            </header>
            <p class="mb-[2em] text-[1em] leading-[1.75]">
              Sed lorem ipsum dolor sit amet nullam consequat feugiat consequat magna
              adipiscing magna etiam amet veroeros. Lorem ipsum dolor tempus sit cursus.
              Tempus nisl et nullam lorem ipsum dolor sit amet aliquam.
            </p>
            <ul class="flex gap-4 m-0 p-0 list-none">
              <li>
                <a href="#" class="inline-block px-[2em] h-[3.25em] leading-[3.25em] border border-[#dddddd] rounded-[8px] text-[#636363] font-semibold hover:text-pink-400 hover:border-pink-400 transition-colors tracking-wide">
                  Learn More
                </a>
              </li>
            </ul>
          </div>
          <div class="w-full md:w-5/12 flex justify-center">
            <Image 
              src={fotoIntro} 
              alt="Intro" 
              class="w-full max-w-[18em] aspect-square object-cover rounded-full border-[0.5em] border-[rgba(222,222,222,0.25)] shadow-sm" 
            />
          </div>
        </div>
      </Section>

      <Section id="first" class="p-[4em] md:p-[5em] text-center border-b border-[#dddddd] bg-[#fbfbfb]">
        <header class="mb-[3em]">
          <h2 class="text-[2.25em] font-bold text-[#636363] tracking-tight">Magna veroeros</h2>
        </header>
        
        <ul class="grid grid-cols-1 md:grid-cols-3 gap-[3em] m-0 p-0 list-none">
          <li class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-[2.25em] h-[2.25em] p-[0.65em] text-[6.25rem] bg-blue-500 rounded-full mb-[1em] border border-[#dddddd] shadow-inner text-white">
              <i class="fas fa-code leading-none"></i>
            </span> 
            <h3 class="text-[1.35em] font-bold text-[#636363] mb-[0.75em]">Ipsum consequat</h3>
            <p class="text-[1em] leading-relaxed m-0 font-light">Sed lorem amet ipsum dolor et amet nullam consequat a feugiat consequat tempus veroeros sed consequat.</p>
          </li>
          <li class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-[2.25em] h-[2.25em] p-[0.65em] text-[6.25rem] bg-purple-500 rounded-full mb-[1em] border border-[#dddddd] shadow-inner text-white">
              <i class="fas fa-copy leading-none"></i>
            </span> 
            <h3 class="text-[1.35em] font-bold text-[#636363] mb-[0.75em]">Amed sed feugiat</h3>
            <p class="text-[1em] leading-relaxed m-0 font-light">Sed lorem amet ipsum dolor et amet nullam consequat a feugiat consequat tempus veroeros sed consequat.</p>
          </li>
          <li class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-[2.25em] h-[2.25em] p-[0.65em] text-[6.25rem] bg-pink-500 rounded-full mb-[1em] border border-[#dddddd] shadow-inner text-white">
              <i class="fas fa-gem leading-none"></i>
            </span> 
            <h3 class="text-[1.35em] font-bold text-[#636363] mb-[0.75em]">Dolor nullam</h3>
            <p class="text-[1em] leading-relaxed m-0 font-light">Sed lorem amet ipsum dolor et amet nullam consequat a feugiat consequat tempus veroeros sed consequat.</p>
          </li>
        </ul>
        
        <footer class="mt-[4em] flex justify-center">
          <a href="#" class="inline-block px-[2em] h-[3.25em] leading-[3.25em] border border-[#dddddd] rounded-[8px] text-[#636363] font-semibold hover:text-pink-400 hover:border-pink-400 transition-colors">
            Learn More
          </a>
        </footer>
      </Section>

      <Section id="second" class="p-[4em] md:p-[5em] text-center border-b border-[#dddddd]">
        <header class="mb-[3em]">
          <h2 class="text-[2.25em] font-bold text-[#636363]">Ipsum consequat</h2>
          <p class="text-[1.2em] mt-4 font-light">Donec imperdiet consequat consequat. Suspendisse feugiat congue posuere.</p>
        </header>

        <ul class="flex flex-wrap justify-center gap-[1.5em] mb-[3em] p-0 list-none">
          <li class="flex flex-col items-center p-[2em] border border-[#dddddd] rounded-[8px] w-[10em] hover:bg-slate-50 transition-colors">
            <span class="text-[2.5em] text-blue-400 mb-2"><i class="fas fa-code-branch"></i></span>
            <strong class="text-[1.75em] text-[#636363] font-bold leading-none">5,120</strong> 
            <span class="text-[0.7em] uppercase tracking-[0.2em] mt-3 font-semibold">Etiam</span>
          </li>
          <li class="flex flex-col items-center p-[2em] border border-[#dddddd] rounded-[8px] w-[10em] hover:bg-slate-50 transition-colors">
            <span class="text-[2.5em] text-purple-400 mb-2"><i class="fas fa-folder-open"></i></span>
            <strong class="text-[1.75em] text-[#636363] font-bold leading-none">8,192</strong> 
            <span class="text-[0.7em] uppercase tracking-[0.2em] mt-3 font-semibold">Magna</span>
          </li>
          <li class="flex flex-col items-center p-[2em] border border-[#dddddd] rounded-[8px] w-[10em] hover:bg-slate-50 transition-colors">
            <span class="text-[2.5em] text-green-400 mb-2"><i class="fas fa-signal"></i></span>
            <strong class="text-[1.75em] text-[#636363] font-bold leading-none">2,048</strong> 
            <span class="text-[0.7em] uppercase tracking-[0.2em] mt-3 font-semibold">Tempus</span>
          </li>
        </ul>

        <p class="text-left leading-relaxed text-[1em] font-light">
          Nam elementum nisl et mi a commodo porttitor. Morbi sit amet nisl eu arcu faucibus hendrerit vel a risus. Nam a orci mi, elementum ac arcu sit amet, fermentum pellentesque et purus. Integer maximus varius lorem, sed convallis diam accumsan sed.
        </p>
      </Section>

      <Section id="cta" class="p-[4em] md:p-[5em] text-center">
        <header class="mb-[3em]">
          <h2 class="text-[2.25em] font-bold text-[#636363] mb-4">Congue imperdiet</h2>
          <p class="text-[1.1em] font-light max-w-2xl mx-auto">Donec imperdiet consequat consequat. Suspendisse feugiat congue posuere. Nulla massa urna, fermentum eget quam aliquet.</p>
        </header>
        
        <footer class="flex justify-center gap-6">
          <a href="#" class="px-[2.5em] h-[3.5em] leading-[3.5em] bg-[#636363] text-white font-bold rounded-[8px] hover:bg-pink-500 transition-colors tracking-wide">
            Get Started
          </a>
          <a href="#" class="px-[2.5em] h-[3.5em] leading-[3.5em] border border-[#dddddd] text-[#636363] font-semibold rounded-[8px] hover:border-pink-400 hover:text-pink-400 transition-colors">
            Learn More
          </a>
        </footer>
      </Section>

    </main>

    <Footer />
    
  </div>
</BaseLayout>
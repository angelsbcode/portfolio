---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import fotoIntro from '../assets/images/pic01.jpg';
---

<BaseLayout title="Stellar by HTML5 UP - Astro Version">
  <div id="wrapper" class="w-[64em] max-w-[calc(100%-4em)] mx-auto py-[4em] flex flex-col">
    
    <Header />

    <div id="nav-sentinel" class="w-full h-px invisible"></div>

    <Nav />

    <main id="main" class="bg-white rounded-b-[0.25em] shadow-xl">

      <Section id="intro" class="p-[4em] md:p-[5em] border-b border-[#dddddd]">
        <div class="flex flex-col-reverse md:flex-row items-center gap-[4em]">
          <div class="flex-1 text-left">
            <header class="mb-[1.5em] relative">
              <h2 class="text-[2.25em] font-light text-[#636363] leading-[1.3] mb-4">Ipsum sed adipiscing</h2>
              <div class="w-[3em] h-[2px] bg-gradient-to-r from-pink-400 to-blue-400"></div>
            </header>
            <p class="mb-[2em] text-[1em]">
              Sed lorem ipsum dolor sit amet nullam consequat feugiat consequat magna
              adipiscing magna etiam amet veroeros. Lorem ipsum dolor tempus sit cursus.
              Tempus nisl et nullam lorem ipsum dolor sit amet aliquam.
            </p>
            <ul class="flex gap-4 m-0 p-0 list-none">
              <li><a href="#" class="inline-block px-[2em] h-[3em] leading-[3em] border border-[#dddddd] rounded-[8px] text-[#636363] hover:text-pink-400 hover:border-pink-400 transition-colors tracking-wide">Learn More</a></li>
            </ul>
          </div>
          <div class="w-full md:w-5/12 flex justify-center">
            <Image 
              src={fotoIntro} 
              alt="Intro" 
              class="w-full max-w-[18em] aspect-square object-cover rounded-full border-[0.5em] border-[rgba(222,222,222,0.25)] shadow-sm" 
            />
          </div>
        </div>
      </Section>

      <Section id="first" class="p-8 md:p-16 text-center border-b border-slate-100 bg-slate-50/50">
        <header class="mb-12">
          <h2 class="text-3xl font-bold text-slate-800">Magna veroeros</h2>
        </header>
        
        <ul class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
          <li class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-36 h-36 bg-blue-500 rounded-full mb-6 border border-slate-200 shadow-sm">
              <i class="fas fa-code text-6xl text-white leading-none"></i>
            </span> 
            <h3 class="text-xl font-bold text-slate-800 mb-4">Ipsum consequat</h3>
            <p class="text-[0.95rem] leading-relaxed">Sed lorem amet ipsum dolor et amet nullam consequat a feugiat consequat tempus veroeros sed consequat.</p>
          </li>

          <li class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-36 h-36 bg-purple-500 rounded-full mb-6 border border-slate-200 shadow-sm">
              <i class="fas fa-copy text-6xl text-white leading-none"></i>
            </span>
            <h3 class="text-xl font-bold text-slate-800 mb-4">Amed sed feugiat</h3>
            <p class="text-[0.95rem] leading-relaxed">Sed lorem amet ipsum dolor et amet nullam consequat a feugiat consequat tempus veroeros sed consequat.</p>
          </li>

          <li class="flex flex-col items-center">
            <span class="inline-flex items-center justify-center w-36 h-36 bg-pink-500 rounded-full mb-6 border border-slate-200 shadow-sm">
              <i class="fas fa-gem text-6xl text-white leading-none"></i>
            </span>
            <h3 class="text-xl font-bold text-slate-800 mb-4">Dolor nullam</h3>
            <p class="text-[0.95rem] leading-relaxed">Sed lorem amet ipsum dolor et amet nullam consequat a feugiat consequat tempus veroeros sed consequat.</p>
          </li>
        </ul>
        
        <footer class="flex justify-center">
          <a href="#" class="px-8 py-3 border border-slate-300 rounded-full text-slate-500 hover:text-pink-400 hover:border-pink-400 transition-colors">Learn More</a>
        </footer>
      </Section>

      </main>

    <Footer />
    
  </div>
</BaseLayout>